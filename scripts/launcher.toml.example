# MaiBot unified launcher config
# Copy to scripts/launcher.toml and edit as needed.

[paths]
# All paths are relative to the repo root (parent of this scripts/ dir).
napcat   = "runtime/napcat"
bot_root = "."

[napcat]
launcher      = "launcher.bat"         # Win11 (wt.exe); 用 "launcher-win10.bat" for Win10 (cmd.exe)
# QQ number for quick login. Leave "" to use QR code login.
# Equivalent to the bare number previously hard-coded in run.bat (e.g. `./launcher-win10.bat 2460714978`).
qq_number     = ""
# Extra positional args forwarded to the launcher bat after qq_number.
# Example: ["-q", "2460714978"] if you prefer the explicit -q form.
extra_args    = []
# NapCat requires Administrator. When true (default) and the launcher is not
# already running as admin, we trigger UAC via ShellExecuteEx('runas') so the
# real elevated process is tracked. Set false if you always launch from an
# already-elevated terminal/PyCharm.
elevate       = true
# Fire-and-forget: spawn napcat and immediately continue to the next component.
# NapCat takes 5-15s to actually listen on 8095; adapter/bot retry internally so
# there's no need to gate startup on the port. Set port>0 to re-enable probing.
ready_port    = 0
ready_timeout = 0
# Extra window title shown in the spawned cmd window.
title         = "NapCatQQ"

[bot]
argv          = ["uv", "run", "--no-sync", "python", "bot.py"]
title         = "MaiBot"

[logs]
dir = "runtime/launcher-logs"          # stdout/stderr when running hidden; always used for .pid files

[startup]
# Order matters: earlier ones start first. Readiness probe gates the next one.
order = ["napcat", "bot"]
